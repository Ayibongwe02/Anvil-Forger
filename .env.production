# Anvil v2 Production Environment Variables
# NEVER commit secrets to version control — use a secure secrets manager

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ANVIL_SECRET_KEY=your-secure-secret-key-here-change-in-production

# Application environment
FLASK_ENV=production
DEBUG=False

# Port (must match docker-compose port mapping)
PORT=5000
